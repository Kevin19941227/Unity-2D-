  lines:
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u7D42\u65BC\u6253\u8DD1\u90A3\u96BB\u72D7\u4E86\uFF01\u771F\u4ED6X\u6709\u5920\u56C9\u55E6\u7684\u3002"
    avatar: {fileID: 21300000, guid: 3b5ccb5f83f5ef343aa9dcbc737a748e, type: 3}
  - speakerName: "\u8001\u95C6"
    sentence: "\u5C0F\u8CF4\uFF0C\u4F60\u80FD\u5230\u9019\u908A\uFF0C\u6211\u5F88\u6B23\u6170\uFF0C\u4F46\u4F60\u4E5F\u77E5\u9053\u73FE\u5728\u9019\u500B\u6642\u5C40\uFF0C\u4E0A\u5C64\u6709\u6C7A\u5B9A\u8A72\u8207\u8AB0\u5171\u9AD4\u6642\u8271....\u6240\u4EE5\uFF0C\u4F60\u88AB\u958B\u9664\u4E86\uFF01\uFF01"
    avatar: {fileID: 21300000, guid: 203f9772d921d4a40ab8c721b5108af7, type: 3}
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u4F60\u4E0D\u5C31\u662F\u4E0A\u5C64\u55CE\uFF1F\u6211\u771F\u7684\u9700\u8981\u9019\u500B\u5DE5\u4F5C\u3002\r\n"
    avatar: {fileID: 21300000, guid: 3b5ccb5f83f5ef343aa9dcbc737a748e, type: 3}
  - speakerName: "\u8001\u95C6"
    sentence: "\u5C0F\u8CF4\u963F\uFF0C\u5C31\u9019\u6A23\u5427\u3002"
    avatar: {fileID: 21300000, guid: 203f9772d921d4a40ab8c721b5108af7, type: 3}
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u90A3\u53EA\u597D\u8B93\u4F60\u8DDF\u90A3\u96BB\u770B\u9580\u72D7\u4E00\u6A23\u7684\u4E0B\u5834\u4E86\u3002"
    avatar: {fileID: 21300000, guid: 3b5ccb5f83f5ef343aa9dcbc737a748e, type: 3}
