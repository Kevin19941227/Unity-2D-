  lines:
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u6B38\uFF01\u5947\u602A\uFF0C\u516C\u53F8\u600E\u9EBC\u4E86\u963F\uFF0C\u90FD\u6C92\u4EBA\u7684\uFF1F"
    avatar: {fileID: 21300000, guid: 3b5ccb5f83f5ef343aa9dcbc737a748e, type: 3}
  - speakerName: "\u72D7(\u8001\u95C6\u7684\u72D7)"
    sentence: "\u4F60\u4F86\u4E86\u963F\uFF01\u5C0F\u8CF4\uFF0C\u6709\u4E00\u4EF6\u4E8B\u901A\u77E5\u4F60\uFF0C\u4F60\u88AB\u958B\u9664\u4E86\uFF01"
    avatar: {fileID: 21300000, guid: 6efb9d8a5aa2b4840953119fa1039002, type: 3}
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u4E0D\uFF01\uFF01\uFF01\u600E\u9EBC\u6703\uFF0C\u4E0D\u884C\u6211\u8981\u8A0E\u4E00\u500B\u8AAA\u6CD5\u3002"
    avatar: {fileID: 21300000, guid: 3b5ccb5f83f5ef343aa9dcbc737a748e, type: 3}
  - speakerName: "\u72D7(\u8001\u95C6\u7684\u72D7)"
    sentence: "\u6C92\u6709\u9019\u500B\u6A5F\u6703\u4E86\uFF0C\u8ACB\u81EA\u52D5\u6EFE\u86CB\u3002"
    avatar: {fileID: 21300000, guid: 6efb9d8a5aa2b4840953119fa1039002, type: 3}
  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u2026\u4E0D\u5148\u6253\u4E00\u67B6\u4F60\u662F\u4E0D\u6703\u9589\u5634\u5C0D\u5427\uFF1F"
