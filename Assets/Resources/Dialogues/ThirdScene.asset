  - speakerName: "\u5C0F\u8CF4"
    sentence: "\u7D42\u65BC\u8FFD\u5230\u4F60\u4E86\uFF0C\u4F60\u5011\u5225\u60F3\u628A\u6211\u6383\u51FA\u9580\u3002"
